{
	"name": "forest-agent-dashboard",
	"version": "0.1.0",
	"description": "A local-first Obsidian dashboard for notes, tasks, mail summaries, and engineering signals.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"check:repo": "node scripts/check-repository.mjs",
		"test": "node --test tests/*.test.mjs",
		"verify": "npm run check:repo && npm run test && npm run lint && npm run build",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"dashboard",
		"notes",
		"gmail",
		"qq-mail"
	],
	"author": "Totoro",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"dependencies": {
		"gsap": "^3.15.0"
	}
}
